<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Camp_FireINVT" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/camp_primary</item>
        <item name="colorPrimaryVariant">@color/camp_primary_variant</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/camp_secondary</item>
        <item name="colorSecondaryVariant">@color/camp_secondary</item>
        <item name="colorOnSecondary">@color/black</item>
        
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        
        <!-- Background color for dark mode -->
        <item name="android:windowBackground">@color/black</item>
    </style>
</resources>
