<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Title at the top -->
    <TextView
        android:id="@+id/splash_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="80dp"
        android:text="Campsite Commander"
        android:textColor="@color/black"
        android:textSize="32sp"
        android:textStyle="bold" />

    <!-- Centered Image -->
    <!-- Note: Placeholder for camp mountain.png -->
    <ImageView
        android:id="@+id/splash_image"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_centerInParent="true"
        android:contentDescription="Camp Mountain"
        android:scaleType="centerInside"
        android:src="@drawable/ic_launcher_foreground" />

    <!-- Subtitle or Loading Indicator -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/splash_image"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:text="Loading Adventure..."
        android:textColor="@color/teal_700"
        android:textSize="18sp" />

</RelativeLayout>
