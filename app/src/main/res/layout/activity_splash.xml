<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/camp_background">

    <!-- Title at the top -->
    <TextView
        android:id="@+id/splash_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="80dp"
        android:text="Campsite Commander"
        android:textColor="@color/camp_primary_variant"
        android:textSize="32sp"
        android:textStyle="bold" />

    <!-- Centered Image -->
    <ImageView
        android:id="@+id/splash_image"
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:layout_centerInParent="true"
        android:contentDescription="Camp Mountain"
        android:scaleType="centerInside"
        android:src="@drawable/ic_mountain" />

    <!-- Subtitle or Loading Indicator -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/splash_image"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:text="Loading Adventure..."
        android:textColor="@color/camp_primary"
        android:textSize="18sp"
        android:textStyle="italic" />

</RelativeLayout>
