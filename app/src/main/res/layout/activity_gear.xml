<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/camp_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="24dp"
        android:paddingRight="24dp"
        android:paddingBottom="24dp"
        android:paddingTop="64dp">

        <!-- Screen title and heading -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Camping Gear"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/camp_primary_variant"
            android:layout_marginBottom="32dp" />

        <!-- Gear item name container -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="Item Name"
            app:boxStrokeColor="@color/camp_primary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edit_gear_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Gear category selection container -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="Category"
            app:boxStrokeColor="@color/camp_primary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edit_gear_category"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Gear item quantity container -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="Quantity"
            app:boxStrokeColor="@color/camp_primary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edit_gear_quantity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Gear notes and comments container -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:hint="Notes / Comments"
            app:boxStrokeColor="@color/camp_primary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edit_gear_notes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:gravity="top" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Save gear item button -->
        <Button
            android:id="@+id/btn_save_gear"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Save Gear Item"
            android:textSize="18sp"
            android:backgroundTint="@color/camp_primary"
            android:layout_marginBottom="16dp" />

        <!-- Back to dashboard button -->
        <Button
            android:id="@+id/btn_gear_back"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Back to Dashboard"
            android:textSize="18sp"
            android:backgroundTint="@color/camp_strongcolor" />

    </LinearLayout>
</ScrollView>
