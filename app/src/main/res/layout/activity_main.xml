<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Dashboard main screen content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@color/camp_background">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Campsite Commander"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/camp_primary_variant"
            android:layout_marginBottom="16dp" />

        <!-- Total items packed counter -->
        <TextView
            android:id="@+id/text_total_items"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total Items Packed: 0"
            android:textSize="18sp"
            android:textColor="@color/gray"
            android:layout_marginBottom="48dp" />

        <Button
            android:id="@+id/btn_gear"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Add Gear"
            android:textSize="18sp"
            android:backgroundTint="@color/camp_primary" />

    </LinearLayout>

    <!-- Semi-transparent loading layer -->
    <LinearLayout
        android:id="@+id/loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/camp_background_transparent"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loading.."
            android:textColor="@color/camp_primary_variant"
            android:textSize="24sp"
            android:textStyle="italic" />

    </LinearLayout>

</FrameLayout>
