<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Dashboard Content (Main Screen) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@color/camp_background">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Campsite Commander"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/camp_primary_variant"
            android:layout_marginBottom="48dp" />

        <Button
            android:id="@+id/btn_gear"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Camping Gear"
            android:textSize="18sp"
            android:backgroundTint="@color/camp_primary"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btn_food"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Food Supply"
            android:textSize="18sp"
            android:backgroundTint="@color/camp_secondary"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btn_checklist"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Complete Checklist"
            android:textSize="18sp"
            android:backgroundTint="@color/camp_accent" />

    </LinearLayout>

    <!-- Semi-transparent Lazy Loading Overlay -->
    <LinearLayout
        android:id="@+id/loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/camp_background_transparent"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="visible">

        <!-- Logo for Lazy Loading -->
        <ImageView
            android:id="@+id/loading_logo"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_marginBottom="24dp"
            android:contentDescription="Campsite Commander Logo"
            android:scaleType="centerInside"
            android:src="@drawable/ic_mountain" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Campsite Commander"
            android:textColor="@color/camp_primary_variant"
            android:textSize="36sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Lazy Loading Gear..."
            android:textColor="@color/camp_primary"
            android:textSize="20sp"
            android:textStyle="italic" />

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:indeterminateTint="@color/camp_primary" />

    </LinearLayout>

</FrameLayout>
